{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Crown-of-Thorns Starfish vs. Live Coral Cover by Reef",
    "subtitle": "Each bubble is one reef survey. Size = number of tows. Use the slider to explore by year.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#1a1a2e",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 420,
  "data": {
    "url": "data/AIMS_MantatowByReef_scatter2019to2023.csv"
  },
  "params": [
    {
      "name": "year_param",
      "value": 2023,
      "bind": {
        "input": "range",
        "min": 2019,
        "max": 2023,
        "step": 1,
        "name": "Year: "
      }
    }
  ],
  "transform": [
    {
      "filter": "datum.Year == year_param"
    },
    {
      "filter": "datum.MEAN_LIVE_CORAL > 0"
    }
  ],
  "mark": {
    "type": "circle",
    "opacity": 0.65,
    "stroke": "white",
    "strokeWidth": 0.5
  },
  "encoding": {
    "x": {
      "field": "MEAN_COTS_PER_TOW",
      "type": "quantitative",
      "title": "Mean Crown-of-Thorns Starfish per Tow",
      "axis": {
        "titleFontSize": 12,
        "labelFontSize": 11
      },
      "scale": {
        "type": "sqrt",
        "domain": [0, 8]
      }
    },
    "y": {
      "field": "MEAN_LIVE_CORAL",
      "type": "quantitative",
      "title": "Mean Live Coral Cover (%)",
      "axis": {
        "titleFontSize": 12,
        "labelFontSize": 11
      },
      "scale": {
        "domain": [0, 80]
      }
    },
    "color": {
      "field": "SECTOR_NAME",
      "type": "nominal",
      "title": "Sector",
      "scale": {
        "domain": [
          "Cairns",
          "Capricorn-Bunker",
          "Cooktown/Lizard Is.",
          "Central",
          "Capricorn",
          "Innisfail",
          "Princess Charlotte Bay",
          "Pompey",
          "Swain",
          "Townsville",
          "Whitsunday"
        ],
        "range": [
          "#e41a1c",
          "#377eb8",
          "#4daf4a",
          "#984ea3",
          "#ff7f00",
          "#a65628",
          "#f781bf",
          "#999999",
          "#e6ab02",
          "#66c2a5",
          "#fc8d62"
        ]
      },
      "legend": {
        "orient": "right",
        "titleFontSize": 11,
        "labelFontSize": 10
      }
    },
    "size": {
      "field": "TOWS",
      "type": "quantitative",
      "title": "Number of tows",
      "scale": {
        "range": [30, 400]
      },
      "legend": {
        "orient": "bottom-right",
        "titleFontSize": 10
      }
    },
    "tooltip": [
      {
        "field": "REEF_NAME",
        "type": "nominal",
        "title": "Reef"
      },
      {
        "field": "SECTOR_NAME",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "SHELF_NAME",
        "type": "nominal",
        "title": "Shelf"
      },
      {
        "field": "MEAN_LIVE_CORAL",
        "type": "quantitative",
        "title": "Live Coral (%)",
        "format": ".1f"
      },
      {
        "field": "MEAN_COTS_PER_TOW",
        "type": "quantitative",
        "title": "CoTS per tow",
        "format": ".2f"
      },
      {
        "field": "TOWS",
        "type": "quantitative",
        "title": "Tows conducted"
      }
    ]
  }
}
