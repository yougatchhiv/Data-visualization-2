{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Figure 8. Total Visits by Management Area",
    "subtitle": "Comparing regions by year",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "anchor": "start"
  },
  "width": 400,
  "height": 500,
  "autosize": { "type": "fit", "contains": "padding" },
  "data": { "url": "data/GBRMP_VisitationsByArea_annual.csv" },
  "params": [
    {
      "name": "year_select",
      "value": "2024",
      "bind": {
        "input": "select",
        "options": [2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025],
        "name": "Year : "
      }
    }
  ],
  "transform": [{ "filter": "datum.Year == year_select" }],
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "Area",
      "type": "nominal",
      "sort": "-y",
      "axis": {
        "title": "Location",
        "labelFontSize": 11,
        "labelAngle": -20
      }
    },
    "y": {
      "field": "Total Visits",
      "type": "quantitative",
      "axis": { "title": "Total Visits", "labelFontSize": 11 }
    },
    "color": {
      "field": "Area",
      "type": "nominal",
      "scale": { "range": ["#1a3f5c", "#c0392b", "#2a9d8f", "#e9c46a"] },
      "legend": null
    },
    "tooltip": [
      { "field": "Area", "type": "nominal", "title": "Management Area" },
      { "field": "Total Visits", "type": "quantitative", "format": "," }
    ]
  }
}
